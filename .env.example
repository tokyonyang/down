# BotFather에서 받은 텔레그램 봇 토큰
TELEGRAM_BOT_TOKEN=1234567890:AA_example_token_here

# 선택사항: 본인만 사용하려면 /id로 확인한 Telegram user ID를 입력
# 여러 명이면 쉼표로 구분: 111111111,222222222
ALLOWED_TELEGRAM_USER_IDS=

# 텔레그램 전송 안정성을 위한 파일 제한. 기본 48MB 추천
MAX_FILE_SIZE_MB=48

# 다운로드 제한 시간. 기본 180초
DOWNLOAD_TIMEOUT_MS=180000

# Supported links include YouTube, Instagram/Reels, Threads, X/Twitter.
